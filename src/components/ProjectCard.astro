---
interface Props {
  name: string;
  url: string;
  description: string;
  tags: string[];
}
const { name, url, description, tags } = Astro.props;
---
<div class="card">
  <div class="card-header">
    <h3>{name}</h3>
    <a href={url} target="_blank" rel="noopener">Live ↗</a>
  </div>
  <p>{description}</p>
  <ul class="tags">
    {tags.map((tag) => <li>{tag}</li>)}
  </ul>
</div>

<style>
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .card-header h3 {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .card-header a {
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--accent);
  }

  .card-header a:hover {
    text-decoration: underline;
  }

  p {
    color: var(--muted);
    font-size: 0.92rem;
    margin-bottom: 1rem;
    max-width: 58ch;
  }

  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags li {
    font-size: 0.78rem;
    background: var(--border);
    color: var(--muted);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
</style>
